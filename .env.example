# STATION8 — Environment variables template
# Copy to .env.local and fill in as integrations come online.
# All are optional during P0 (foundation). Each phase adds its own.

# ── Site ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Sanity CMS (P3) ──
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# ── Resend + Turnstile — booking form (P6) ──
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
BOOKING_INBOX=

# ── Instagram Graph API (P6) ──
# Long-lived token, auto-refreshed via Vercel Cron
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ── Mapbox (P5) ──
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Sentry (P0, deferred until DSN available) ──
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
